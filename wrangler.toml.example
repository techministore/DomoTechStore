# Configuración de ejemplo para Cloudflare Pages Functions
# Copia este archivo a wrangler.toml y completa las credenciales

name = "domotechstore"
compatibility_date = "2024-01-01"

[vars]
# AliExpress API Keys (opcional)
ALI_APP_KEY = "tu_app_key_aqui"
ALI_APP_SECRET = "tu_app_secret_aqui"
ALI_TRACKING_ID = "tu_tracking_id_aqui"

# Banggood API Keys (las que proporcionaste)
BANGGOOD_APP_KEY = "aff6a1a99947bda"
BANGGOOD_APP_SECRET = "tu_app_secret_completo_aqui"
BANGGOOD_AFFILIATE_ID = "tu_affiliate_id_aqui" # Opcional
